# =====================================================================
# DaDamDa - Environment Variables Template
# Copy this file to .env and fill in real values.
# Never commit the real .env file.
# =====================================================================

# ---- Common ----
ENV=development
LOG_LEVEL=INFO

# ---- PostgreSQL ----
POSTGRES_USER=dadamda
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dadamda
DATABASE_URL=postgresql+psycopg://dadamda:changeme@postgres:5432/dadamda

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Backend (FastAPI) ----
JWT_SECRET=changeme
# Comma-separated allowed origins. Defaults to localhost if unset.
# CORS_ORIGINS=http://localhost,http://localhost:3000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_APP_NAME=DaDamDa
NEXT_PUBLIC_VERSION=0.1.0
