# =====================================================================
# DaDamDa - Production Environment Template (Ubuntu VM deployment)
# Copy to .env on the server and fill in real secrets.
# Never commit the real .env file.
# Domain: dadamda.duckdns.org (DuckDNS A record -> 141.147.179.193)
# =====================================================================

# ---- Common ----
ENV=production
LOG_LEVEL=INFO

# ---- PostgreSQL ----
POSTGRES_USER=dadamda
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=dadamda
DATABASE_URL=postgresql+psycopg://dadamda:CHANGE_ME_STRONG_PASSWORD@postgres:5432/dadamda

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Backend (FastAPI) ----
JWT_SECRET=CHANGE_ME_RANDOM_SECRET
CORS_ORIGINS=https://dadamda.duckdns.org

# ---- Frontend (Next.js) ----
# NEXT_PUBLIC_* values are baked into the build (see docker-compose.prod.yml
# build.args), so changing them requires rebuilding the frontend image.
NEXT_PUBLIC_API_URL=https://dadamda.duckdns.org/api/v1
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_APP_NAME=DaDamDa
NEXT_PUBLIC_VERSION=0.1.0
